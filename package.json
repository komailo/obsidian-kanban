{
  "name": "obsidian-kanban",
  "version": "1.0.0",
  "description": "A modern, feature-rich Kanban board for Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "kanban",
    "board",
    "task-management"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  },
  "dependencies": {
    "@types/flatpickr": "^3.0.2",
    "@types/mdast": "^4.0.4",
    "flatpickr": "^4.6.13",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm-task-list-item": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-gfm-task-list-item": "^2.1.0",
    "obsidian": "latest"
  }
}
